#!/usr/bin/env bash
# =============================================================================
# pre-commit hook — migration naming guard
# Installed automatically via: bash scripts/install-hooks.sh
#
# Blocks commits that introduce migration files with invalid names.
# Same rules as scripts/check-migration-names.sh (CI mirror).
# =============================================================================
set -euo pipefail

MIGRATIONS_DIR="supabase/migrations"

# Only run if migration files are staged
STAGED_MIGRATIONS=$(git diff --cached --name-only | grep "^${MIGRATIONS_DIR}/.*\.sql$" || true)
[[ -z "$STAGED_MIGRATIONS" ]] && exit 0

echo ""
echo "🔍 pre-commit: vérification des noms de migrations..."

ERRORS=0
KNOWN_EXCEPTIONS=("20260430_016_blog_enrichissement.sql")

declare -A ALL_VERSIONS

# Check ALL files in the directory (not just staged) to catch duplicate prefixes
for filepath in "$MIGRATIONS_DIR"/*.sql; do
  [[ -e "$filepath" ]] || continue
  fname=$(basename "$filepath")

  is_exception=0
  for ex in "${KNOWN_EXCEPTIONS[@]}"; do
    [[ "$fname" == "$ex" ]] && is_exception=1 && break
  done
  [[ $is_exception -eq 1 ]] && continue

  prefix="${fname%%[^0-9]*}"

  if [[ ${#prefix} -lt 11 ]]; then
    echo "  ❌ $fname"
    echo "     Préfixe '$prefix' trop court (${#prefix} chiffres < 11)."
    echo "     Format : YYYYMMDDNNN_description.sql"
    echo "     Exemple : 20260501001_add_my_feature.sql"
    ERRORS=$((ERRORS + 1))
    continue
  fi

  if ! [[ "$fname" =~ ^[0-9]{11,}_[a-z][a-z0-9_]*\.sql$ ]]; then
    echo "  ❌ $fname"
    echo "     Format invalide — attendu : YYYYMMDDNNN_description_minuscules.sql"
    ERRORS=$((ERRORS + 1))
    continue
  fi

  if [[ -v "ALL_VERSIONS[$prefix]" ]]; then
    echo "  ❌ Préfixe dupliqué '$prefix' :"
    echo "     ${ALL_VERSIONS[$prefix]}"
    echo "     $fname"
    ERRORS=$((ERRORS + 1))
  else
    ALL_VERSIONS[$prefix]="$fname"
  fi
done

if [[ $ERRORS -gt 0 ]]; then
  echo ""
  echo "  🚫 Commit bloqué — $ERRORS fichier(s) de migration invalide(s)."
  echo "     Consultez supabase/MIGRATIONS_RULES.md"
  echo ""
  exit 1
fi

echo "  ✅ Nommage migrations OK."
